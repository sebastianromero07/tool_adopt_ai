# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ==========================================
# ENVIRONMENT VARIABLES - SECRETOS
# ==========================================
# ⚠️ CRITICAL: Never commit these files
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
.env.*.example  # Template files for env variables

# ==========================================
# DEPENDENCIES
# ==========================================
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ==========================================
# TESTING
# ==========================================
/coverage
.nyc_output

# ==========================================
# BUILD OUTPUT
# ==========================================
/.next/
/out/
/build
/dist

# ==========================================
# PRODUCTION BUILD ARTIFACTS
# ==========================================
*.tsbuildinfo
next-env.d.ts

# ==========================================
# MISC FILES
# ==========================================
.DS_Store
*.pem
.AppleDouble
.LSOverride

# ==========================================
# DEBUG & LOG FILES
# ==========================================
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*
.wrangler/
.env.*.mjs

# ==========================================
# IDE & EDITOR FILES
# ==========================================
.vscode
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~
.DS_Store
.VSCode
.vscode-test
.swcache

# ==========================================
# OS SPECIFIC
# ==========================================
Thumbs.db
ehthumbs.db
.DS_Store
.AppleDouble
.LSOverride
._*
.localized

# ==========================================
# VERCEL & DEPLOYMENT
# ==========================================
.vercel
*.vercel

# ==========================================
# IDE TEMP FILES
# ==========================================
*.sublime-workspace
*.sublime-project
.fleet
.idea/

# ==========================================
# API KEY BACKUPS (Just in case)
# ==========================================
*.key
*.pem
*.cert
.private

# ==========================================
# CACHE
# ==========================================
.eslintcache
.stylelintcache
.cache/
.turbo/

# ==========================================
