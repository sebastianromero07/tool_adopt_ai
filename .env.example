# =========================================
# AdoptAI - Environment Variables Template
# =========================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env.local
# 2. Fill in the values from your services
# 3. NEVER commit .env.local to git
# 4. .env.local is in .gitignore (checked automatically)
#
# cp .env.example .env.local
#

# =========================================
# SUPABASE - Database & Authentication
# =========================================
# Get these from: https://app.supabase.com → Settings → API

# Public URL (safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Public API Key (safe to expose, read-only access)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ⚠️ PRIVATE - Service Role Key (server-side only)
# THIS GIVES ADMINISTRATIVE ACCESS - KEEP PRIVATE!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# =========================================
# GOOGLE GEMINI - AI Generation
# =========================================
# Get this from: https://aistudio.google.com/app/apikey

# ⚠️ PRIVATE - API Key for Google AI APIs
GOOGLE_API_KEY=AIzaSy...


# =========================================
# RESEND - Email Service
# =========================================
# Get API Key from: https://resend.com/api-keys

# ⚠️ PRIVATE - API Key for sending emails
RESEND_API_KEY=re_...

# Email address where team notifications are sent
# (this can be internal, so you get notified of new leads)
NOTIFICATION_EMAIL=your-team@company.com


# =========================================
# APP CONFIGURATION
# =========================================

# Public URL of the application
# In development: http://localhost:3000
# In production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment
# development | production | test
NODE_ENV=development


# =========================================
# SECURITY NOTES
# =========================================
#
# NEVER COMMIT THIS FILE (.env.local) TO GIT
# It's in .gitignore - make sure git ignores it
#
# Check before committing:
#   git status
#   # Should NOT show .env.local
#
# If you accidentally commit secrets:
#   1. ROTATE all API keys immediately
#   2. Remove from git: git rm --cached .env.local
#   3. Update API keys in all services
#   4. Commit the fix: git commit -m "Security: Remove and rotate secrets"
#
# For production deployment:
#   - Add variables in your platform's UI (Vercel, Railway, etc)
#   - Do NOT copy-paste entire .env.local file
#   - Use different values for production
#
